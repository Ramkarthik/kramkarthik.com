---
interface Props {
  url: string;
}

const { url } = Astro.props;

interface OEmbedResponse {
  author_name: string;
  author_url: string;
  html: string;
  url: string;
}

let tweet: OEmbedResponse | null = null;
let tweetText = '';
let tweetDate = '';
let username = '';

try {
  const oembedUrl = `https://publish.twitter.com/oembed?url=${encodeURIComponent(url)}&omit_script=true&dnt=true`;
  const res = await fetch(oembedUrl);
  if (res.ok) {
    tweet = await res.json() as OEmbedResponse;

    // Extract @username from author_url
    username = tweet.author_url.split('/').filter(Boolean).pop() || '';

    // Extract tweet body (content of <p> tag)
    const pMatch = tweet.html.match(/<p[^>]*>([\s\S]*?)<\/p>/i);
    if (pMatch) {
      tweetText = pMatch[1];
    }

    // Extract date from the last <a> tag in the blockquote
    const lastAMatch = tweet.html.match(/(?:.*<a[^>]*>)([^<]+)<\/a>[^<]*<\/blockquote>/is);
    if (lastAMatch) {
      tweetDate = lastAMatch[1].trim();
    }
  }
} catch {
  // silently fall through to error state
}

const initials = tweet
  ? tweet.author_name.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase()
  : '?';
---

{tweet ? (
  <div class="tweet-card">
    <!-- Header -->
    <div class="tweet-header">
      <div class="tweet-avatar" aria-hidden="true">{initials}</div>
      <div class="tweet-author-info">
        <a href={tweet.author_url} target="_blank" rel="noopener noreferrer" class="tweet-display-name">
          {tweet.author_name}
        </a>
        <div class="tweet-handle-row">
          <span class="tweet-handle">@{username}</span>
          {tweetDate && <><span class="tweet-sep">·</span><a href={url} target="_blank" rel="noopener noreferrer" class="tweet-date-link">{tweetDate}</a></>}
        </div>
      </div>
      <a href={url} target="_blank" rel="noopener noreferrer" class="tweet-x-logo" aria-label="View on X">
        <svg width="18" height="18" viewBox="0 0 1200 1227" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.163 519.284ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.828Z" fill="currentColor"/>
        </svg>
      </a>
    </div>

    <!-- Tweet body -->
    <div class="tweet-body" set:html={tweetText} />
  </div>
) : (
  <div class="tweet-error">
    <p>Could not load tweet. <a href={url} target="_blank" rel="noopener noreferrer">View on X &rarr;</a></p>
  </div>
)}

<style>
  .tweet-card {
    margin: 2rem 0;
    padding: 20px;
    background: #fff;
    border: 1px solid #e1e8ed;
    border-radius: 16px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    max-width: 560px;
    transition: background 0.15s ease;
  }

  .tweet-card:hover {
    background: #f7f9f9;
  }

  /* Header */
  .tweet-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .tweet-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #657786, #aab8c2);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  .tweet-author-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
    min-width: 0;
  }

  .tweet-display-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: #0f1419;
    text-decoration: none;
    border: none !important;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tweet-display-name:hover {
    text-decoration: underline;
    opacity: 1;
    border: none !important;
  }

  .tweet-handle-row {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  .tweet-handle {
    font-size: 0.85rem;
    color: #536471;
    line-height: 1.3;
  }

  .tweet-sep {
    font-size: 0.85rem;
    color: #8899a6;
    line-height: 1.3;
  }

  .tweet-x-logo {
    color: #0f1419;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    border: none !important;
    opacity: 0.85;
  }

  .tweet-x-logo:hover {
    opacity: 1;
    border: none !important;
  }

  /* Body */
  .tweet-body {
    font-size: 1rem;
    line-height: 1.55;
    color: #0f1419;
    margin-bottom: 14px;
    word-break: break-word;
  }

  .tweet-body :global(a) {
    color: #1d9bf0;
    text-decoration: none;
    font-weight: 400;
    border: none !important;
  }

  .tweet-body :global(a:hover) {
    text-decoration: underline;
    border: none !important;
    opacity: 1;
  }

  /* Date */
  .tweet-date-link {
    font-size: 0.85rem;
    color: #8899a6;
    text-decoration: none;
    border: none !important;
    line-height: 1.3;
  }

  .tweet-date-link:hover {
    color: #1d9bf0;
    text-decoration: underline;
    border: none !important;
    opacity: 1;
  }

  /* Error fallback */
  .tweet-error {
    margin: 1.5rem 0;
    padding: 16px 20px;
    background: #f7f9f9;
    border: 1px solid #e1e8ed;
    border-radius: 12px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 0.9rem;
    color: #536471;
  }

  .tweet-error p {
    margin: 0;
  }
</style>
