---
interface Props {
  postNumber: number;
  dayNumber: number;
}

const { postNumber, dayNumber } = Astro.props;

const postPercent = Math.min((postNumber / 100) * 100, 100).toFixed(1);
const dayPercent = Math.min((dayNumber / 365) * 100, 100).toFixed(1);
---

<aside class="offload-card">
  <span class="offload-badge">#100DaysToOffload</span>

  <p class="offload-body">
    This post is part of the <strong>#100DaysToOffload</strong> challenge - writing
    100 posts in one year.
  </p>

  <div class="offload-progress">
    <div class="progress-row">
      <div class="progress-label">
        <span>Posts</span>
        <span class="progress-fraction">{postNumber} / 100</span>
      </div>
      <div class="progress-track" role="progressbar" aria-valuenow={postNumber} aria-valuemin={0} aria-valuemax={100}>
        <div class="progress-fill" style={`width: ${postPercent}%`}></div>
      </div>
    </div>

    <div class="progress-row">
      <div class="progress-label">
        <span>Days</span>
        <span class="progress-fraction">{dayNumber} / 365</span>
      </div>
      <div class="progress-track" role="progressbar" aria-valuenow={dayNumber} aria-valuemin={0} aria-valuemax={365}>
        <div class="progress-fill" style={`width: ${dayPercent}%`}></div>
      </div>
    </div>
  </div>
</aside>

<style>
  .offload-card {
    margin-top: 3rem;
    background: var(--color-highlight-bg);
    border-left: 4px solid var(--color-accent-border);
    border-radius: 0 8px 8px 0;
    padding: 24px;
    font-family: 'IBM Plex Sans', sans-serif;
  }

  .offload-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .offload-body {
    font-family: 'Merriweather', serif;
    font-size: 0.9rem;
    color: var(--color-medium-gray);
    line-height: 1.7;
    margin: 0 0 1.25rem;
  }

  .offload-body strong {
    color: var(--color-darker-text);
    font-weight: 600;
  }

  .offload-progress {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .progress-row {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .progress-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-dark-text);
  }

  .progress-fraction {
    font-weight: 400;
    color: var(--color-light-gray);
  }

  .progress-track {
    width: 100%;
    height: 6px;
    background: var(--color-light-border);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--color-accent), transparent);
    min-width: 6px;
    transition: width 0.4s ease;
  }
</style>