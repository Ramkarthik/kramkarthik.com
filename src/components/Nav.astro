---
const { pathname } = Astro.url;
import { AppConfig } from "../utils/AppConfig";
---

<nav role="navigation">
  <div class="nav-brand">
    <a href="/">
      RAM<span>KARTHIK</span>
    </a>
  </div>
  <div class="nav-links">
    {
      AppConfig.pages.map((p) => {
        const isActive =
          pathname === p.link ||
          (p.link !== "/" && pathname.startsWith(p.link));
        return (
          <a href={p.link} class={isActive ? "active" : ""}>
            {p.name}
          </a>
        );
      })
    }
  </div>
</nav>

<style>
  nav {
    padding: 30px 0;
    margin-bottom: 80px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: "IBM Plex Sans", sans-serif;
  }
  .nav-brand a {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-darker-text);
    letter-spacing: -0.5px;
    border: none !important;
    text-transform: uppercase;
  }
  .nav-brand span {
    color: var(--color-accent);
    font-weight: 400;
  }
  .nav-links {
    display: flex;
    gap: 24px;
  }
  .nav-links a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-light-gray);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: none !important;
    position: relative;
    padding: 4px 0;
  }
  .nav-links a:after {
    content: "";
    position: absolute;
    width: 0;
    height: 1.5px;
    bottom: 0;
    left: 0;
    background-color: var(--color-accent);
    transition: width 0.3s ease;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-darker-text);
  }
  .nav-links a:hover:after,
  .nav-links a.active:after {
    width: 100%;
  }

  @media (max-width: 600px) {
    nav {
      flex-direction: column;
      gap: 20px;
      margin-bottom: 50px;
      align-items: center;
      text-align: center;
    }
    .nav-links {
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .nav-links a {
      font-size: 0.75rem;
    }
  }
</style>
