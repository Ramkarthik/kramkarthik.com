---
import Base from "@/layouts/Base.astro";
import { AppConfig } from "@/utils/AppConfig";
---

<Base
  props={{
    title: "About | " + AppConfig.author,
    description: AppConfig.description,
    image: AppConfig.image,
  }}
>
  <header class="animate-up">
    <h1>About</h1>
  </header>
  <hr class="divider-large animate-up delay-1" />
  <section class="animate-up delay-1">
    <p>Work in progress. More about me coming soon.</p>
  </section>
</Base>
