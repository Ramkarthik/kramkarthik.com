---
import { getCollection } from "astro:content";
import { capitalize } from "@/utils/string";

export interface ListPostProps {
  props: {
    key: "essays" | "notes" | "programming" | "lists" | "all";
    showSummary: boolean;
    limit: number;
    showDate?: boolean;
  };
}

const {
  props: { key, showSummary, limit, showDate = false },
} = Astro.props as ListPostProps;

const allPosts = await getCollection("posts");
const posts =
  key === "all"
    ? allPosts.filter((p) => p.data.category !== "lists")
    : allPosts.filter((p) => p.data.category === key);

let sortedPosts = posts

  .sort((a, b) => {
    return +new Date(b.data.createdDate) - +new Date(a.data.createdDate);
  })
  .slice(0, limit);

const getUrl = (p: any) => {
  return p.data.category === "essays"
    ? `/${p.slug}`
    : `/${p.data.category}/${p.slug}`;
};
---

<div class="post-list">
  <ul>
    {
      sortedPosts.map((p) => {
        return (
          <li class="post-item">
            <a href={getUrl(p)} class="post-link">
              <span class="post-title">{p.data.title}</span>
              {showDate && <span class="post-date">{p.data.createdDate}</span>}
            </a>

            {showSummary && <p class="post-summary">{p.data.summary}</p>}
          </li>
        );
      })
    }
  </ul>
</div>

<style>
  .list-title {
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 0.9rem;
    color: var(--color-light-gray);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 30px;
    font-weight: 600;
  }
  ul {
    padding-left: 0;
    list-style: none;
  }
  .post-item {
    margin-bottom: 35px;
  }
  .post-link {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: space-between;
    gap: 15px;
    border: none !important;
    text-decoration: none;
  }
  .post-date {
    font-size: 0.95rem;
    color: var(--color-light-gray);
    font-family: "IBM Plex Sans", sans-serif;
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .post-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-darker-text);
    line-height: 1.2;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
  }
  .post-title:after {
    content: "→";
    margin-left: 8px;
    font-size: 1.1rem;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
    color: var(--color-accent);
  }
  .post-link:hover .post-title {
    color: var(--color-accent);
  }
  .post-link:hover .post-title:after {
    opacity: 1;
    transform: translateX(0);
  }

  .post-summary {
    font-size: 1rem;
    color: var(--color-medium-gray);
    margin-top: 10px;
    font-style: italic;
    line-height: 1.5;
  }
</style>
